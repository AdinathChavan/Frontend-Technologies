    console.log("Null state and district ...");
    state = "Maharashtra";
    district = "Kolhapur";
  }

  this.api.getMarketData(state, district).subscribe({
    next:(res:any)=>{
      console.log(state,district);
      console.log(res.records);
      this.marketProducts.set(res.records);
    },
    error:(err)=>{
      console.log(err);
    }
  })
}

searchTerm = signal('');

filteredMarketProducts = computed(() => {
  const term = this.searchTerm().toLowerCase();
  const data = this.marketProducts();

  if (!term) return data;

  return data.filter(item =>
    item.Commodity.toLowerCase().includes(term) ||
    item.Market.toLowerCase().includes(term) ||
    item.District.toLowerCase().includes(term)
  );
});


