  getInitials(name: string): string {
  return name
    .split(' ')
    .map(word => word.charAt(0).toUpperCase())
    .join('');
}

  toggleSidebar(): void {
    this.sidebarCollapsed = !this.sidebarCollapsed;
  }

  toggleNotifications(): void {
    this.notificationPanelOpen = !this.notificationPanelOpen;
    this.profileMenuOpen = false;
  }

  toggleProfileMenu(): void {
    this.profileMenuOpen = !this.profileMenuOpen;
    this.notificationPanelOpen = false;
  }

  markAllRead(): void {
    this.notifications.forEach(n => n.read = true);
  }

  getStatusClass(status: string): string {
    const map: Record<string, string> = {
      active: 'status-active',
      inactive: 'status-inactive',
      pending: 'status-pending',
      approved: 'status-approved',
      rejected: 'status-rejected',
      under_review: 'status-review',
    };
    return map[status] || '';
  }

  getStatusLabel(status: string): string {
    return status.replace('_', ' ').replace(/\b\w/g, c => c.toUpperCase());
  }

  getBarHeight(count: number): string {
    const max = Math.max(...this.monthlyRegistrations.map(m => m.count));
    return `${(count / max) * 100}%`;
  }

  getExpenseBarWidth(total: number): string {
    const max = Math.max(...this.expenseCategories.map(e => e.total));
    return `${(total / max) * 100}%`;
  }

  get totalExpenses(): number {
    return this.expenseCategories.reduce((sum, e) => sum + e.total, 0);
  }

  get greeting(): string {
    const h = this.currentTime.getHours();
    if (h < 12) return 'Good Morning';
    if (h < 17) return 'Good Afternoon';
    return 'Good Evening';
  }

  approveScheme(id: string): void {
    const s = this.schemes().find(s => s.farmerId === id);
    if (s) s.status = 'approved';
  }

  rejectScheme(id: string): void {
    const s = this.schemes().find(s => s.farmerId === id);
    if (s) s.status = 'rejected';
  }

  verifyLand(id: string): void {
    const l = this.landRecords.find(l => l.id === id);
    if (l) l.verified = true;
  }




  
